{
  "name": "bookmark-rebalancer",
  "version": "0.2.0",
  "private": true,
  "description": "AI-powered bookmark manager for developers. Save, organize, and rediscover your bookmarks with intelligence.",
  "keywords": [
    "bookmarks",
    "bookmark-manager",
    "browser-extension",
    "ai",
    "productivity",
    "developer-tools",
    "hono",
    "bun",
    "wxt"
  ],
  "homepage": "https://github.com/sandikodev/bookmark-rebalancer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandikodev/bookmark-rebalancer.git"
  },
  "bugs": {
    "url": "https://github.com/sandikodev/bookmark-rebalancer/issues"
  },
  "license": "MIT",
  "author": "sandikodev",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "packages/*",
    "backend",
    "cli",
    "extension"
  ],
  "scripts": {
    "backend:dev": "bun run --cwd backend dev",
    "backend:build": "bun run --cwd backend build",
    "cli:dev": "bun run --cwd cli dev",
    "cli:build": "bun run --cwd cli build",
    "extension:dev": "bun run --cwd extension dev",
    "extension:build": "bun run --cwd extension build",
    "test": "bun run --cwd backend test"
  }
}
